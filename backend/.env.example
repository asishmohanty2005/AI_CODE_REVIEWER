# Application
APP_NAME=CodeLens AI
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Database (Neon PostgreSQL in production; SQLite for local demo)
DATABASE_URL=sqlite+aiosqlite:///./codelens.db
# DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?sslmode=require

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://codelens-ai.vercel.app

# AI Providers
GEMINI_API_KEY=your-google-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
DEFAULT_AI_PROVIDER=gemini
GEMINI_MODEL=gemini-2.0-flash
OPENAI_MODEL=gpt-4o-mini

# Frontend URL (for emails / redirects)
FRONTEND_URL=http://localhost:5173
